{
  "buildCommand": "npm install --prefix frontend && npm run build --prefix frontend",
  "outputDirectory": "frontend/build",
  "functions": {
    "backend/index.js": {}
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
